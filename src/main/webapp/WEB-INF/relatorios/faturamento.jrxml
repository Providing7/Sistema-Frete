            <!-- Status  x=752  w=30 -->
            <staticText>
                <reportElement mode="Opaque" x="752" y="0" width="30"  height="22" forecolor="#FFFFFF" backcolor="#2C3E50" uuid="22222222-0002-0002-0002-000000000010"/>
