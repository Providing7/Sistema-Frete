<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="fretes_aberto" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="9918de00-5255-4946-bbdd-83e15adf7088">
	<queryString>
		<![CDATA[SELECT
	f.numero,
	rem.razao_social AS remetente,
	dest.razao_social AS destinatario,
	mot.nome AS motorista,
	f.municipio_destino ||'/'||f.uf_destino AS destino,
	f.data_previsao_entrega,
	f.valor_total,
	f.status,
	CASE
		WHEN f.data_previsao_entrega < CURRENT_DATE
		THEN (CURRENT_DATE - f.data_previsao_entrega)
		ELSE 0
	 END AS dias_atraso
	FROM frete f
	JOIN cliente rem ON rem.id = f.id_remetente
	JOIN cliente dest ON dest.id = f.id_destinatario
	JOIN motorista mot ON mot.id = f.id_motorista
	WHERE f.status IN ('EMITIDO', 'SAIDA_CONFIRMADA', 'EM_TRANSITO')
	ORDER BY f.data_previsao_entrega ASC]]>
	</queryString>
	<field name="numero" class="java.lang.String"/>
	<field name="remetente" class="java.lang.String"/>
	<field name="destinatario" class="java.lang.String"/>
	<field name="motorista" class="java.lang.String"/>
	<field name="destino" class="java.lang.String"/>
	<field name="data_previsao_entrega" class="java.sql.Date"/>
	<field name="valor_total" class="java.math.BigDecimal"/>
	<field name="status" class="java.lang.String"/>
	<field name="dias_atraso" class="java.lang.Integer"/>
	<variable name="TOTAL_VALOR" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor_total}]]></variableExpression>
		<initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
	</variable>
