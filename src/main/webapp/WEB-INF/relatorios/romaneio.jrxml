<!-- Created with Jaspersoft Studio version 6.21.5.final using JasperReports Library version 6.21.5-74d586df47b25dbd05bd0957999819196e59934a  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="romaneio" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="782" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="863db318-7682-4678-a5b8-15045c3312fa">
	<parameter name="ID_MOTORISTA" class="java.lang.Long"/>
	<parameter name="DATA_INICIO" class="java.lang.String"/>
	<parameter name="DATA_FIM" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
                f.numero,
                rem.razao_social                               AS remetente,
                dest.razao_social                              AS destinatario,
                f.municipio_destino || ' / ' || f.uf_destino   AS destino,
                f.descricao_carga,
                f.peso_kg,
                f.volumes,
                f.valor_total,
                f.status,
                mot.nome                                       AS motorista,
                mot.cnh_numero,
                mot.cnh_categoria,
                v.placa                                        AS veiculo_placa,
                v.tipo                                         AS veiculo_tipo,
                v.capacidade_kg
            FROM frete f
            JOIN cliente   rem  ON rem.id  = f.id_remetente
            JOIN cliente   dest ON dest.id = f.id_destinatario
            JOIN motorista mot  ON mot.id  = f.id_motorista
            JOIN veiculo   v    ON v.id    = f.id_veiculo
            WHERE f.id_motorista = $P{ID_MOTORISTA}
              AND f.data_emissao BETWEEN CAST($P{DATA_INICIO} AS DATE)
                                     AND CAST($P{DATA_FIM}    AS DATE)
            ORDER BY f.data_emissao ASC, f.numero ASC]]>
	</queryString>
	<field name="numero" class="java.lang.String"/>
	<field name="remetente" class="java.lang.String"/>
	<field name="destinatario" class="java.lang.String"/>
	<field name="destino" class="java.lang.String"/>
	<field name="descricao_carga" class="java.lang.String"/>
	<field name="peso_kg" class="java.math.BigDecimal"/>
	<field name="volumes" class="java.lang.Integer"/>
	<field name="valor_total" class="java.math.BigDecimal"/>
	<field name="status" class="java.lang.String"/>
	<field name="motorista" class="java.lang.String"/>
	<field name="cnh_numero" class="java.lang.String"/>
	<field name="cnh_categoria" class="java.lang.String"/>
	<field name="veiculo_placa" class="java.lang.String"/>
	<field name="veiculo_tipo" class="java.lang.String"/>
	<field name="capacidade_kg" class="java.math.BigDecimal"/>
	<variable name="TOTAL_PESO" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{peso_kg}]]></variableExpression>
		<initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_VOLUMES" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{volumes}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_VALOR" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{valor_total}]]></variableExpression>
		<initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
	</variable>
	<variable name="QTD_FRETES" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{numero}]]></variableExpression>
		<initialValueExpression><![CDATA[0]]></initialValueExpression>
	</variable>
